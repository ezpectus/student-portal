# Student Portal — Environment Configuration Example
# Copy this file to .env.development (local) or .env.production (deployed) and fill in your values.
#
# ── Deployment modes ──────────────────────────────────────────
# 1. Local dev:       NEXT_PUBLIC_LOCAL_AUTH=true,  NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true
# 2. Portfolio demo:  NEXT_PUBLIC_LOCAL_AUTH=true,  NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true
# 3. Real production: NEXT_PUBLIC_LOCAL_AUTH=false, NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false
# ──────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
NEXT_PUBLIC_ENV=development

# API
API_BASE_URL=http://localhost:5000

# Cookies
MAIN_COOKIE_DOMAIN=localhost
ROOT_COOKIE_DOMAIN=localhost

# Local Database (SQLite for dev, Neon Postgres for prod)
DATABASE_URL="file:./dev.db"

# JWT secret for local auth system — MUST be at least 16 characters.
# Generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-secret-at-least-16-chars"

# Remote JWT signature verification (optional — enables JWKS-based verification)
# When set, external JWTs are verified against the JWKS endpoint instead of decode-only.
# Ask your backend team for the JWKS URI (e.g. https://api.example.com/.well-known/jwks.json)
# JWKS_URI=
# JWT_ISSUER=

# Enable local auth mode (bypasses remote API for demo)
NEXT_PUBLIC_LOCAL_AUTH=true

# Show test account shortcuts only in a public demo deployment
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# Production ownership: frontend/server actions use DATABASE_URL for standalone demo;
# a separate backend should own its own DATABASE_URL and expose API_BASE_URL to this app.

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# reCAPTCHA (optional, for password reset)
NEXT_PUBLIC_RECAPTCHA_KEY=

# Login carousel images (optional)
NEXT_PUBLIC_CAROUSEL_CDN_BASE_URL=

# Support links (optional)
NEXT_PUBLIC_SUGGESTIONS_FORM=
NEXT_PUBLIC_WHATSAPP_SUPPORT_LINK=

# Social links (optional)
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# Document URLs (optional)
NEXT_PUBLIC_KBIS_URL=
NEXT_PUBLIC_ADDRESS_URL=
NEXT_PUBLIC_CODE_OF_HONOR=
NEXT_PUBLIC_INTERNAL_REGULATIONS=
NEXT_PUBLIC_EDUCATIONAL_ORGANIZATION_REGULATION=
NEXT_PUBLIC_PROGRAM_ANTICORRUPTION=
NEXT_PUBLIC_USER_MANUAL_URL=
NEXT_PUBLIC_STUDENT_MANUAL_URL=
NEXT_PUBLIC_CAMPUS_DOCUMENT_TEMPLATE=

# University links (optional)
NEXT_PUBLIC_SCHEDULE_URL=
NEXT_PUBLIC_DNVR=
NEXT_PUBLIC_UNIVERSITY_NOTICE_BOARD_URL=
NEXT_PUBLIC_LIBRARY_DISCOVERY_URL=
NEXT_PUBLIC_UNIVERSITY_NEWS=
NEXT_PUBLIC_STUDENT_COUNCIL=
