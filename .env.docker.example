# ─── Student Portal Docker Environment ───────────────────────────────
# Copy this file to .env.docker and fill in your values.
# .env.docker is loaded by docker-compose.yml via env_file.

# ─── App ─────────────────────────────────────────────────────────────
APP_PORT=3000
API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_LOCAL_AUTH=true

# ─── Security ────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret for production (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-to-a-strong-secret

# ─── Cookies ─────────────────────────────────────────────────────────
MAIN_COOKIE_DOMAIN=localhost
ROOT_COOKIE_DOMAIN=localhost

# ─── Database ────────────────────────────────────────────────────────
DB_PORT=5432
POSTGRES_PASSWORD=portal_secret

# ─── Database initialization ─────────────────────────────────────────
# Set RUN_DB_PUSH=true to apply schema on container start (idempotent)
RUN_DB_PUSH=true
# Set SEED_DATABASE=true + ALLOW_DESTRUCTIVE_SEED=true to seed demo data
SEED_DATABASE=false
ALLOW_DESTRUCTIVE_SEED=false

# ─── Dev profile (docker compose --profile dev up) ───────────────────
ADMINER_PORT=8080

# ─── Feature toggles (all default to enabled) ────────────────────────
# Set to "false" to disable a feature
# NEXT_PUBLIC_FEATURE_DARK_MODE=true
# NEXT_PUBLIC_FEATURE_COMMAND_PALETTE=true
# NEXT_PUBLIC_FEATURE_REALTIME_NOTIFICATIONS=true
# NEXT_PUBLIC_FEATURE_ADMIN_PANEL=true
